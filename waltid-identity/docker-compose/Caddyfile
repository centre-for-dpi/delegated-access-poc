{
	auto_https off
	admin off
}

# Wallet API
:{$WALLET_BACKEND_PORT} {
    reverse_proxy http://wallet-api:{$WALLET_BACKEND_PORT}
}

# Issuer API
:{$ISSUER_API_PORT} {
    reverse_proxy http://issuer-api:{$ISSUER_API_PORT}
}

# Verifier API
:{$VERIFIER_API_PORT} {
    reverse_proxy http://verifier-api:{$VERIFIER_API_PORT}
}

# Verifier API2
:{$VERIFIER_API2_PORT} {
    reverse_proxy http://verifier-api2:{$VERIFIER_API2_PORT}
}


# Web Demo Wallet Frontend
:{$DEMO_WALLET_FRONTEND_PORT} {
    reverse_proxy http://waltid-demo-wallet:{$DEMO_WALLET_FRONTEND_PORT} # frontend
    reverse_proxy /wallet-api/* http://wallet-api:{$WALLET_BACKEND_PORT} # backend
}

# Web Dev Wallet Frontend
:{$DEV_WALLET_FRONTEND_PORT} {
    reverse_proxy http://waltid-dev-wallet:{$DEV_WALLET_FRONTEND_PORT} # frontend
    reverse_proxy /wallet-api/* http://wallet-api:{$WALLET_BACKEND_PORT} # backend
}

# Web Portal
:{$WEB_PORTAL_PORT} {
    reverse_proxy http://web-portal:{$WEB_PORTAL_PORT}
}

# VC Repo
:{$VC_REPO_PORT} {
    reverse_proxy http://vc-repo:{$VC_REPO_PORT}
}

# Verification Adapter
:{$VERIFICATION_ADAPTER_PORT} {
    reverse_proxy http://verification-adapter:{$VERIFICATION_ADAPTER_PORT}
}

# Issuer Portal
:{$ISSUER_PORTAL_PORT} {
    reverse_proxy http://issuer-portal:{$ISSUER_PORTAL_PORT}
}

# Verification Portal
:{$VERIFICATION_PORTAL_PORT} {
    reverse_proxy http://verification-portal:{$VERIFICATION_PORTAL_PORT}
}

# Inji Verify — routes /v1/verify/* to Java verify-service, everything else to React UI
# vc-verification is intercepted by the pixelpass-adapter first so it can detect
# JSON-LD credentials encoded in PixelPass QRs (which arrive as application/vc+sd-jwt)
# and re-submit them to the Java service as application/vc+ld+json.
:{$INJI_VERIFY_UI_PORT} {
    route /v1/verify/vc-verification {
        reverse_proxy http://pixelpass-adapter:{$PIXELPASS_ADAPTER_PORT}
    }
    route /v1/verify/* {
        reverse_proxy http://inji-verify-service:8080
    }
    reverse_proxy http://inji-verify-ui:8000
}

# PixelPass Adapter — offline QR generator for Walt.id credentials
:{$PIXELPASS_ADAPTER_PORT} {
    reverse_proxy http://pixelpass-adapter:{$PIXELPASS_ADAPTER_PORT}
}

# Go Wallet (ldp_vc credential wallet)
:{$GO_WALLET_PORT} {
    reverse_proxy http://go-wallet:{$GO_WALLET_PORT}
}

# OID4VP Adapter (ldp_vc verifier via OID4VP)
:{$OIDC4VP_ADAPTER_PORT} {
    reverse_proxy http://oidc4vp-adapter:{$OIDC4VP_ADAPTER_PORT}
}

# pgAdmin
:{$PG_ADMIN_PORT} {
    reverse_proxy http://phpmyadmin:{$PG_ADMIN_PORT}
}